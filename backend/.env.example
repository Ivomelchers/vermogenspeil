# Lokale ontwikkeling — kopieer naar .env
# Productie-variabelen: zie docs/development/DEPLOYMENT.md

DEBUG=True
SECRET_KEY=change-me-in-development
DATABASE_URL=postgres://user:password@localhost:5432/vermogenspeil
REDIS_URL=redis://localhost:6379/0
ENCRYPTION_KEY=
CELERY_TASK_ALWAYS_EAGER=

# Pre-launch: true = iedereen Premium-features. Bij livegang: false
PREMIUM_UNLOCKED_FOR_ALL=true

# Betalingen (fase 7, nog niet nodig voor MVP)
MOLLIE_API_KEY=

# E-mail (optioneel lokaal; console backend zonder EMAIL_HOST)
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Koersen (gratis stack) ---
# Live: Yahoo (ETF/aandelen) + Bitvavo ticker (crypto) + optioneel CoinGecko fallback
# Cache 5 min; Celery beat ververs elke 5 min (productie: worker + beat draaien)
PRICE_CACHE_TTL_LIVE_SECONDS=300
BITVAVO_API_URL=https://api.bitvavo.com/v2
# Optioneel; ms (standaard 10000). Zelfde waarde als op Bitvavo API-key.
BITVAVO_ACCESS_WINDOW=10000
BYBIT_API_URL=https://api.bybit.com
BYBIT_RECV_WINDOW=5000
OKX_API_URL=https://www.okx.com
# Optioneel: CoinGecko Demo key (gratis account) — betere crypto-limieten + attribution in UI
# COINGECKO_API_KEY=
# OPENFIGI_ENABLED=true
# OPENFIGI_API_KEY=
# INSTRUMENT_RESOLVE_MAX_PER_IMPORT=15

# --- CSV AI-kolommapping (fallback) ---
# Alleen OPENAI_API_KEY zetten = AI-fallback AAN. Uitzetten: CSV_AI_COLUMN_MAPPING=false
# CSV_AI_DESCRIPTION_CLASSIFICATION=false
# OPENAI_API_KEY=sk-...
# CSV_AI_COLUMN_MODEL=gpt-4o-mini
# LEARNED_ALIAS_GLOBAL_MIN_USERS=2
# LEARNED_ALIAS_CRITICAL_MIN_USERS=3

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
DEFAULT_FROM_EMAIL=noreply@mijnvermogen.nl

# Auth0 (verplicht voor login)
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=backend-management-client-id
AUTH0_CLIENT_SECRET=backend-management-client-secret
AUTH0_FRONTEND_CLIENT_ID=frontend-spa-client-id
PASSWORD_RESET_TOKEN_HOURS=1
