# Lokale ontwikkeling — kopieer naar .env
# Productie-variabelen: zie docs/development/DEPLOYMENT.md

DEBUG=True
SECRET_KEY=change-me-in-development
DATABASE_URL=postgres://user:password@localhost:5432/vermogenspeil
REDIS_URL=redis://localhost:6379/0
ENCRYPTION_KEY=
CELERY_TASK_ALWAYS_EAGER=
# Pre-launch: true = iedereen Premium-features. Bij livegang: false
PREMIUM_UNLOCKED_FOR_ALL=true
MOLLIE_API_KEY=
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
BITVAVO_API_URL=https://api.bitvavo.com/v2
PRICE_API_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
DEFAULT_FROM_EMAIL=noreply@mijnvermogen.nl

# Auth0 
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=backend-management-client-id
AUTH0_CLIENT_SECRET=backend-management-client-secret
AUTH0_FRONTEND_CLIENT_ID=frontend-spa-client-id
PASSWORD_RESET_TOKEN_HOURS=1
